# zer0DAYSlater environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then load it before running:
#   source .env

# --- Required ---

# Authentication token sent with all C2 communications
ZDS_AUTH_TOKEN=your_token_here

# WebSocket C2 server URL (used by exfil_ws and agent_core)
ZDS_C2_WS_URL=wss://your-c2-server:8765

# HTTPS exfil endpoint (used by exfil_https)
ZDS_HTTPS_ENDPOINT=https://your-c2-server/api

# --- Optional (have defaults) ---

# DNS exfil control domain (used by exfil_dns)
ZDS_CONTROL_DOMAIN=your.c2.domain

# Plugin server base URL (used by plugin_fetcher)
ZDS_PLUGIN_SERVER=https://your-c2-server

# Comma-separated peer IPs for mesh C2 (used by c2_mesh_agent)
ZDS_PEERS=192.168.1.10,192.168.1.11

# MQTT broker address and port (defaults: 127.0.0.1, 1883)
ZDS_MQTT_BROKER=127.0.0.1
ZDS_MQTT_PORT=1883

# mTLS mesh port and tuning (defaults: 9009, 5.0s, 30s, 16 peers)
ZDS_MESH_PORT=9009
ZDS_MESH_TIMEOUT=5.0
ZDS_HEARTBEAT_INTERVAL=30
ZDS_MAX_PEERS=16

# LLM model for llm_operator (default: mistral:latest)
ZDS_LLM_MODEL=mistral:latest

# Run mode: live or dry-run (default: live)
ZDS_MODE=live
