# Copy to .env and source before running
# Use ZDS_MODE=demo to run without real infrastructure

ZDS_MODE=demo

ZDS_AUTH_TOKEN=demo_token
ZDS_C2_WS_URL=ws://127.0.0.1:8765
ZDS_HTTPS_ENDPOINT=http://127.0.0.1:8000/api
ZDS_PLUGIN_SERVER=http://127.0.0.1:8000
ZDS_CONTROL_DOMAIN=localhost
ZDS_PEERS=127.0.0.1
ZDS_LLM_MODEL=mistral:latest
ZDS_MESH_PORT=9000
ZDS_MESH_TIMEOUT=30
ZDS_MAX_PEERS=10
ZDS_HEARTBEAT_INTERVAL=15
ZDS_MQTT_BROKER=127.0.0.1
ZDS_MQTT_PORT=1883
